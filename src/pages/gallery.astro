---
import MainLayout from "../layouts/MainLayout.astro";
import GalleryLightbox from "../components/GalleryLightbox";
import { bgmTracks } from "../data/bgm";
import { galleryPhotos } from "../data/gallery";
import { withBase } from "../utils/with-base";

const base = import.meta.env.BASE_URL;
const photos = galleryPhotos.map((photo) => ({
  ...photo,
  original: withBase(photo.original, base),
  src: withBase(photo.src, base),
  thumb: withBase(photo.thumb, base),
}));
const tracks = bgmTracks.map((track) => ({
  ...track,
  src: withBase(track.src, base),
}));
---

<MainLayout
  title="相簿"
  description="以滑動為主的婚紗相簿，手機與桌機都能舒服瀏覽。"
>
  <section class="gallery-header">
    <div>
      <h1>WE'RE GETTING MARRIED.</h1>
    </div>
  </section>

  <GalleryLightbox client:load photos={photos} bgmTracks={tracks} />
</MainLayout>
