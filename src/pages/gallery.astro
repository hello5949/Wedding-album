---
import MainLayout from "../layouts/MainLayout.astro";
import GalleryLightbox from "../components/GalleryLightbox";
import { galleryPhotos } from "../data/gallery";
import { withBase } from "../utils/with-base";

const base = import.meta.env.BASE_URL;
const photos = galleryPhotos.map((photo) => ({
  ...photo,
  src: withBase(photo.path, base),
}));
---

<MainLayout
  title="Gallery"
  description="Full wedding gallery with a swipe-first browsing experience."
>
  <section class="gallery-header">
    <div>
      <p class="section-label">Gallery</p>
      <h1>A calmer way to move through the album, one frame at a time.</h1>
    </div>
    <p class="gallery-intro">
      Swipe on mobile, use the side controls on desktop, or jump with the
      thumbnail strip below. The layout now stays focused on a single image.
    </p>
  </section>

  <GalleryLightbox client:load photos={photos} />
</MainLayout>
